# =============================================================================
# FawnCortex 环境变量配置模板
# =============================================================================
# 使用方式：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 填入你的真实 API Key 和模型信息
#   3. 确保 .env 已加入 .gitignore，切勿提交到版本控制
# =============================================================================

ENV=development


# =============================================================================
# 1. 全局默认 LLM 配置（OpenAI 兼容格式）
# =============================================================================
# 当各智能体未配置独立参数时，自动回退到此全局配置。
# 支持的供应商示例：SiliconFlow、DashScope、OpenAI、Moonshot 等

LLM_API_KEY="sk-your-key-here"
LLM_BASE_URL="https://api.siliconflow.cn/v1"
LLM_MODEL_NAME="Qwen/Qwen3-8B"


# =============================================================================
# 2. 多智能体独立 LLM 配置（可选）
# =============================================================================
# 为不同智能体配置不同模型，可在效果与成本之间取得平衡。
# 若留空，则自动回退到上面的全局默认配置。
#
# 简单智能体（对话、表情、反思）建议使用轻量级模型：
#   - qwen3.5-9b、Qwen/Qwen3.6-8B 等
# 复杂智能体（大脑、记忆）建议使用推理能力更强的模型：
#   - qwen3.5-35b-a3b、Qwen/Qwen3.6-27B、DeepSeek-V4 等

# --- ChatAgent（前台对话）---
CHAT_LLM_API_KEY=""
CHAT_LLM_BASE_URL=""
CHAT_LLM_MODEL_NAME=""

# --- EmotionAgent（表情/语气控制）---
# 提示：config.py 中 emotion 默认沿用 chat_agent 的配置，
# 如需独立配置，请先修改 config.py 中的 LLM_ROLE_CONFIG
EMOTION_LLM_API_KEY=""
EMOTION_LLM_BASE_URL=""
EMOTION_LLM_MODEL_NAME=""

# --- BrainAgent（后台深度思考，ReAct + 工具调用）---
BRAIN_LLM_API_KEY=""
BRAIN_LLM_BASE_URL=""
BRAIN_LLM_MODEL_NAME=""

# --- ReflectionAgent（反思判断）---
# 提示：config.py 中 reflection 默认沿用 brain_agent 的配置
REFLECTION_LLM_API_KEY=""
REFLECTION_LLM_BASE_URL=""
REFLECTION_LLM_MODEL_NAME=""

# --- Memory（长期记忆系统）---
# 提示：config.py 中 memory 默认沿用 brain_agent 的配置
MEMORY_LLM_API_KEY=""
MEMORY_LLM_BASE_URL=""
MEMORY_LLM_MODEL_NAME=""


# =============================================================================
# 3. 向量嵌入模型配置（长期记忆用）
# =============================================================================
# 用于 mem0 长期记忆的向量嵌入生成
# 推荐：Qwen/Qwen3-Embedding-0.6B（轻量且中文效果好）

EMBEDDING_API_KEY="sk-your-key-here"
EMBEDDING_BASE_URL="https://api.siliconflow.cn/v1"
EMBEDDING_MODEL_NAME="Qwen/Qwen3-Embedding-0.6B"


# =============================================================================
# 4. ASR 语音识别配置（Web 模式语音输入用）
# =============================================================================
# 推荐：FunAudioLLM/SenseVoiceSmall

ASR_API_KEY="sk-your-key-here"
ASR_BASE_URL="https://api.siliconflow.cn/v1/audio/transcriptions"
ASR_MODEL_NAME="FunAudioLLM/SenseVoiceSmall"


# =============================================================================
# 5. TTS 语音合成配置
# =============================================================================
# 推荐模型：FunAudioLLM/CosyVoice2-0.5B
# 音色格式：FunAudioLLM/CosyVoice2-0.5B:<speaker_name>
# 示例音色：diana、alex、anna、bella 等

TTS_API_KEY="sk-your-key-here"
TTS_BASE_URL="https://api.siliconflow.cn/v1/audio/speech"
TTS_MODEL_NAME="FunAudioLLM/CosyVoice2-0.5B"
TTS_VOICE="FunAudioLLM/CosyVoice2-0.5B:diana"


# =============================================================================
# 6. 工具类 API 配置（可选，留空则对应工具不可用）
# =============================================================================

# --- Semantic Scholar 论文搜索 ---
# 免费申请地址：https://www.semanticscholar.org/product/api
S2_API_KEY=""

# --- 腾讯联网搜索（WSA）---
# 文档地址：https://cloud.tencent.com/document/product/1806/130615
TENCENT_CLOUD_WSA_APIKEY=""
